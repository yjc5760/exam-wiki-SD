  "concepts": [
    {
      "concept_id": "SD-C-001",
      "name_zh": "單自由度系統（SDOF）",
      "name_en": "Single Degree of Freedom System",
      "classification": "SD-U1-3",
      "definition": "以單一廣義座標描述其動態行為的理想化結構系統，由質量 m、彈簧剛度 k、阻尼係數 c 組成。",
      "key_formula": "mẍ + cẋ + kx = F(t)",
      "related_concept_ids": ["SD-C-002", "SD-C-003", "SD-C-004"]
    },
    {
      "concept_id": "SD-C-002",
      "name_zh": "自然圓頻率（ω₀）與自然週期（T）",
      "name_en": "Natural Circular Frequency and Period",
      "classification": "SD-U1-1",
      "definition": "無阻尼 SDOF 系統自由振動的角頻率與週期，是結構動力特性最重要的參數。",
      "key_formula": "ω₀ = √(k/m)；T = 2π/ω₀；f = 1/T",
      "related_concept_ids": ["SD-C-001", "SD-C-003", "SD-C-005"]
    },
    {
      "concept_id": "SD-C-003",
      "name_zh": "阻尼比（ξ）",
      "name_en": "Damping Ratio",
      "classification": "SD-U1-1",
      "definition": "實際阻尼係數與臨界阻尼係數之比。欠阻尼（ξ<1）為工程結構典型狀態，典型值 2%~5%。",
      "key_formula": "ξ = c / (2mω₀) = c / ccr；ccr = 2mω₀；ωd = ω₀√(1−ξ²)",
      "related_concept_ids": ["SD-C-001", "SD-C-002", "SD-C-006"]
    },
    {
      "concept_id": "SD-C-004",
      "name_zh": "動力放大係數（D）",
      "name_en": "Dynamic Magnification Factor",
      "classification": "SD-U1-3",
      "definition": "穩態強迫振動的最大動態位移與靜態位移之比。共振（r≈1）時 D_max ≈ 1/(2ξ)。",
      "key_formula": "D = 1/√[(1−r²)²+(2ξr)²]；r = Ω/ω₀（頻率比）；X = D·F₀/k",
      "related_concept_ids": ["SD-C-001", "SD-C-003", "SD-C-005"]
    },
    {
      "concept_id": "SD-C-005",
      "name_zh": "反應譜（Response Spectrum）",
      "name_en": "Response Spectrum",
      "classification": "SD-U1-3",
      "definition": "特定地震輸入下，以自然週期 T 為橫軸，記錄不同週期 SDOF 系統最大反應的曲線，是耐震設計的核心工具。",
      "key_formula": "Sd(T,ξ) = max|u(t)|；Sv ≈ (2π/T)·Sd；Sa ≈ (2π/T)²·Sd = ω₀²·Sd",
      "related_concept_ids": ["SD-C-002", "SD-C-006", "SD-C-010"]
    },
    {
      "concept_id": "SD-C-006",
      "name_zh": "Duhamel 積分",
      "name_en": "Duhamel Integral",
      "classification": "SD-U1-3",
      "definition": "將任意激振視為連續脈衝疊加，利用脈衝反應函數求解線性 SDOF 系統的精確時域反應。",
      "key_formula": "x(t) = (1/mωd)∫₀ᵗ F(τ)·e^[−ξω₀(t−τ)]·sin[ωd(t−τ)]dτ",
      "related_concept_ids": ["SD-C-001", "SD-C-003", "SD-C-005"]
    },
    {
      "concept_id": "SD-C-007",
      "name_zh": "模態疊加法（Modal Superposition）",
      "name_en": "Modal Superposition Method",
      "classification": "SD-U1-3",
      "definition": "將 MDOF 系統的動態反應分解為各獨立模態的疊加，每個模態以等效 SDOF 求解後再組合，是多自由度系統動力分析的核心方法。",
      "key_formula": "x(t) = Σ {φ}ᵢ·qᵢ(t)；各模態：q̈ᵢ+2ξᵢωᵢq̇ᵢ+ωᵢ²qᵢ = Γᵢ·üg",
      "related_concept_ids": ["SD-C-008", "SD-C-009", "SD-C-005"]
    },
    {
      "concept_id": "SD-C-008",
      "name_zh": "振態向量（Mode Shape）",
      "name_en": "Mode Shape / Eigenvector",
      "classification": "SD-U1-3",
      "definition": "MDOF 系統特徵值問題的解，描述各自由度在某模態下的相對振動形狀，具有質量矩陣正交性。",
      "key_formula": "([K]−ω²[M]){φ}={0}；{φ}ᵢᵀ[M]{φ}ⱼ = δᵢⱼ（正交性）",
      "related_concept_ids": ["SD-C-007", "SD-C-009"]
    },
    {
      "concept_id": "SD-C-009",
      "name_zh": "模態參與因子（Γᵢ）與有效質量",
      "name_en": "Modal Participation Factor and Effective Mass",
      "classification": "SD-U1-3",
      "definition": "反映各模態對地震輸入的貢獻程度。有效質量驗算：Σm*ᵢ = 總質量，確保模態截取的完整性。",
      "key_formula": "Γᵢ = {φ}ᵢᵀ[M]{1} / ({φ}ᵢᵀ[M]{φ}ᵢ)；m*ᵢ = Γᵢ²·({φ}ᵢᵀ[M]{φ}ᵢ)",
      "related_concept_ids": ["SD-C-007", "SD-C-008"]
    },
    {
      "concept_id": "SD-C-010",
      "name_zh": "等效靜力法（設計地震力）",
      "name_en": "Equivalent Static Force Method",
      "classification": "SD-U2-2",
      "definition": "將地震慣性力以等效靜力 V 施加於結構，適用於規則結構的簡化設計方法，為台灣建築耐震規範主要方法。",
      "key_formula": "V = Sa(T)·W/g；V ≥ SD1·Ie·W/(T·R)；V ≤ SDS·Ie·W/R",
      "related_concept_ids": ["SD-C-005", "SD-C-011", "SD-C-012"]
    },
    {
      "concept_id": "SD-C-011",
      "name_zh": "設計反應譜（SDS、SD1）",
      "name_en": "Design Response Spectrum",
      "classification": "SD-U2-2",
      "definition": "台灣建築耐震規範之設計地震反應譜，由 Ss（短週期）和 S1（1秒週期）基準加速度，乘以場址類別放大係數後取 2/3 得設計值。",
      "key_formula": "SDS = (2/3)·Fa·Ss；SD1 = (2/3)·Fv·S1；Ts = SD1/SDS；T₀ = 0.2·Ts",
      "related_concept_ids": ["SD-C-005", "SD-C-010", "SD-C-012"]
    },
    {
      "concept_id": "SD-C-012",
      "name_zh": "反應修正係數（R）",
      "name_en": "Response Modification Factor",
      "classification": "SD-U2-2",
      "definition": "耐震設計中反映結構韌性與過強度的折減係數。R 越大，設計地震力越小，但需要更高的韌性細部設計要求。",
      "key_formula": "V = SDS·Ie·W/R；R 值：特殊矩形框架 = 8；中間矩形框架 = 5；剪力牆 = 5～6",
      "related_concept_ids": ["SD-C-010", "SD-C-011"]
    },
    {
      "concept_id": "SD-C-013",
      "name_zh": "隔震系統（Seismic Isolation）",
      "name_en": "Seismic Isolation System",
      "classification": "SD-U3-2",
      "definition": "在結構底部設置低水平剛度的隔震層，延長整體結構週期使之遠離地盤卓越週期，大幅降低上部結構加速度反應。",
      "key_formula": "TIS = 2π√(W/g·Keff)；DD = g·SD1·TIS/(4π²·BD)；BD 依等效阻尼比查表",
      "related_concept_ids": ["SD-C-014", "SD-C-015"]
    },
    {
      "concept_id": "SD-C-014",
      "name_zh": "等效線性化（隔震/消能系統）",
      "name_en": "Equivalent Linearization",
      "classification": "SD-U3-2",
      "definition": "將非線性隔震或消能元件以等效割線剛度和等效阻尼比取代，使系統可用線性反應譜方法進行分析設計。",
      "key_formula": "Keff = F_max/D_max（割線剛度）；βeff = WD/(2π·Keff·D²)（等效阻尼比）",
      "related_concept_ids": ["SD-C-013", "SD-C-015"]
    },
    {
      "concept_id": "SD-C-015",
      "name_zh": "消能減震（被動控制）",
      "name_en": "Supplemental Damping / Energy Dissipation",
      "classification": "SD-U3-2",
      "definition": "在結構中附加粘滯阻尼器、摩擦阻尼器或 BRB 等消能元件，提高系統阻尼比，有效降低地震反應位移和加速度。",
      "key_formula": "ξeq = WD/(4π·Ke·umax²)；F_粘滯 = C·|u̇|^α（α=1為線性）",
      "related_concept_ids": ["SD-C-013", "SD-C-014", "SD-C-003"]
    },
    {
      "concept_id": "SD-C-016",
      "name_zh": "SRSS 與 CQC 模態組合",
      "name_en": "SRSS and CQC Modal Combination",
      "classification": "SD-U1-3",
      "definition": "反應譜分析中各模態最大反應的組合規則。SRSS 適用頻率相差明顯的情形；CQC 考慮模態間相關性，適用密集頻率。",
      "key_formula": "SRSS: R = √(ΣRᵢ²)；CQC: R = √(ΣΣρᵢⱼ·Rᵢ·Rⱼ)；ρᵢⱼ 依頻率比與阻尼比計算",
      "related_concept_ids": ["SD-C-007", "SD-C-009"]
    },
    {
      "concept_id": "SD-C-017",
      "name_zh": "橋梁耐震設計（α 法）",
      "name_en": "Bridge Seismic Design (Alpha Method)",
      "classification": "SD-U2-3",
      "definition": "台灣橋梁耐震規範的等效靜力設計方法，以設計地震加速度係數 A 乘以場址修正係數 S 計算等效地震力。",
      "key_formula": "P = A·S·C·W；C = 1.2S/T^(2/3) ≤ 2.5A；重要性因子 I：生命線1.5/主要1.25/一般1.0",
      "related_concept_ids": ["SD-C-010", "SD-C-011"]
    }
  ]
}
